{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pico Debug (OpenOCD + SWD)",
            "type": "cortex-debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/glcd.elf",
            "request": "launch",
            "servertype": "openocd",
            "device": "RP2040",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2040.cfg"
            ],
            "svdFile": "C:/Program Files/Raspberry Pi/Pico SDK v1.5.1/pico-sdk/src/rp2040/hardware_regs/rp2040.svd",
            "runToEntryPoint": "main",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "gdbPath": "C:/Program Files/Raspberry Pi/Pico SDK v1.5.1/gcc-arm-none-eabi/bin/arm-none-eabi-gdb.exe",
            "serverpath": "C:/Program Files/Raspberry Pi/Pico SDK v1.5.1/openocd/openocd.exe",
            "searchDir": [
                "C:/Program Files/Raspberry Pi/Pico SDK v1.5.1/openocd/scripts"
            ]
        }
    ]
}
