{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Pico: Build",
            "type": "shell",
            "command": "${workspaceFolder}/build.cmd",
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Pico: Clean Build",
            "type": "shell",
            "command": "${workspaceFolder}/build.cmd",
            "args": ["clean"],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Pico: Flash via picotool",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "call \"${workspaceFolder}/pico-env.cmd\" && picotool load -x \"${workspaceFolder}/build/glcd.uf2\" -f"
            ],
            "problemMatcher": [],
            "dependsOn": "Pico: Build"
        }
    ]
}
